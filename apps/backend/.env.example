# Environment Configuration
NODE_ENV=development
PORT=3001

# Google OAuth Configuration
GOOGLE_CLIENT_ID=Your_Google_Client_ID_here
GOOGLE_CLIENT_SECRET=Your_Google_Client_Secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/callback

# Admin / longcelot-sheet-db configuration
# ADMIN_SHEET_ID: the central admin spreadsheet lsdb reads/writes (create it
# once, share it with SUPER_ADMIN_EMAIL as editor). Holds the admin.users
# account registry (both Google + password accounts, one row per user).
ADMIN_SHEET_ID=Your_Admin_Google_Sheet_ID_here
# SUPER_ADMIN_EMAIL: required by lsdb's createUserSheet (always shares new
# user sheets with this address as editor) and used to bootstrap the admin
# OAuth adapter the first time this account logs in.
SUPER_ADMIN_EMAIL=admin@example.com
# ADMIN_EMAILS: comma-separated allowlist computing `role` at login/register
# (superset of SUPER_ADMIN_EMAIL, which is always included).
# ADMIN_EMAILS=admin@example.com,ops@example.com

# Redis — persists the admin account's own Google OAuth tokens (adapter
# bootstrap, key `lsdb:admin-tokens`) and the per-user TokenStore backing
# lsdb's tokenStore option (captures a user's Google tokens at signup so
# their sheet can be created in their own Drive).
REDIS_URL=redis://localhost:6379

# Optional: only needed for local lsdb CLI usage (lsdb validate/sync/status),
# not by the app itself.
# DEV_USER_SHEET_ID=

# JWT Configuration
JWT_SECRET=development-secret-key-change-in-production-supersecurekey123456789
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=d8df0a64f19a35a640a816dd1ab883cb369e3a1709c2d1207385dde6d6efe818f3357d32ba25d140eecebb5a909fd059332fe361ad5be27d69e165e3a34a900c
JWT_REFRESH_EXPIRES_IN=30d

# Security Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=Your_Actual_Bot_Token_Here
TELEGRAM_BOT_USERNAME=Your_Bot_Username_Here
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/api/v1/telegram/webhook

# Environment Configuration
NODE_ENV=development
PORT=3001

# Google OAuth Configuration (will be filled after Google Cloud setup)
GOOGLE_CLIENT_ID=Your_Google_Client_ID_here
GOOGLE_CLIENT_SECRET=Your_Google_Client_Secret_here
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/auth/google/callback

# Admin / longcelot-sheet-db configuration
# ADMIN_SHEET_ID: the central admin spreadsheet lsdb reads/writes (create it once, share it with SUPER_ADMIN_EMAIL as editor)
ADMIN_SHEET_ID=Your_Admin_Google_Sheet_ID_here
# SUPER_ADMIN_EMAIL: kept for backward compatibility; ADMIN_EMAILS (comma-separated) is preferred for more than one admin
SUPER_ADMIN_EMAIL=admin@example.com
# ADMIN_EMAILS=admin@example.com,ops@example.com

# Redis (used to persist the admin account's Google OAuth tokens for the
# sheet-db adapter — see src/services/sheetDb/adapter.ts)
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=development-secret-key-change-in-production-supersecurekey123456789
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=d8df0a64f19a35a640a816dd1ab883cb369e3a1709c2d1207385dde6d6efe818f3357d32ba25d140eecebb5a909fd059332fe361ad5be27d69e165e3a34a900c
JWT_REFRESH_EXPIRES_IN=30d

# Security Configuration
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
FRONTEND_URL=http://localhost:3000
HMAC_SECRET=your-hmac-secret-key-change-in-production-min-32-chars-long

# Database Configuration (for OTP Telegram Integration)
DATABASE_URL=postgresql://postgres:password@localhost:5432/budget_managing
DATABASE_CLIENT=pg

# Logging
LOG_LEVEL=debug

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=Your_Actual_Bot_Token_Here
TELEGRAM_BOT_USERNAME=Your_Bot_Username_Here
TELEGRAM_WEBHOOK_URL=https://your-ngrok-url.ngrok-free.app/api/v1/telegram/webhook

# Ngrok Configuration  
NGROK_AUTHTOKEN=Your_Ngrok_Auth_Token_Here
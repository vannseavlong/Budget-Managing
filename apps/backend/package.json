{
  "name": "@budget-managing/backend",
  "version": "1.0.0",
  "description": "Backend API server for Budget Managing application",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathPattern=unit --passWithNoTests",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist",
    "security:check": "pnpm audit && snyk test",
    "telegram:setup": "node setup-telegram.js",
    "telegram:setup-ngrok": "node setup-telegram-ngrok.js",
    "migrate": "dotenv -e .env -- npx knex --knexfile ./node_modules/otp-telegram-longcelot/knexfile.cjs --migrations-directory $(pwd)/migrations migrate:latest",
    "migrate:rollback": "dotenv -e .env -- npx knex --knexfile ./node_modules/otp-telegram-longcelot/knexfile.cjs --migrations-directory $(pwd)/migrations migrate:rollback"
  },
  "dependencies": {
    "@ngrok/ngrok": "^1.5.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^9.15.1",
    "googleapis": "^128.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "longcelot-sheet-db": "^0.1.39",
    "morgan": "^1.10.0",
    "otp-telegram-longcelot": "^0.1.5",
    "pg": "^8.18.0",
    "redis": "^4.6.10",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^11.1.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.2.0",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "knex": "^3.1.0",
    "rimraf": "^5.0.5",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.6.0",
    "typescript": "^5.3.2"
  },
  "private": true
}